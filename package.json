{
  "name": "npm-dep-mgr",
  "version": "2.0.2",
  "description": "Check for newer versions of dependencies.",
  "main": "src/logic.js",
  "bin": {
    "npm-dep-mgr": "cli.js"
  },
  "files": [
    "src",
    "cli.js"
  ],
  "scripts": {
    "prettier": "npx prettier --ignore-path .gitignore --check .",
    "prettier:fix": "npx prettier --ignore-path .gitignore --write .",
    "test": "node --test test/*.*js",
    "versions": "npx npm-dep-mgr check",
    "versions:fix": "npx npm-dep-mgr update",
    "test:coverage": "npx c8 --reporter=text --reporter=text-summary npm test",
    "format": "npm run prettier:fix"
  },
  "author": "Tadeusz Makuch",
  "license": "MIT",
  "dependencies": {
    "semver": "^7.7.4"
  },
  "directories": {
    "lib": "src",
    "test": "test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/msimerson/npm-dep-mgr.git"
  },
  "keywords": [
    "git",
    "npm",
    "check",
    "versions",
    "updates"
  ],
  "bugs": {
    "url": "https://github.com/msimerson/npm-dep-mgr/issues"
  },
  "homepage": "https://www.npmjs.com/package/npm-dep-mgr",
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "trailingComma": "all"
  }
}
